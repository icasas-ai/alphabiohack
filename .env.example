# Supabase Auth / Storage
# Required by the current auth flow even when PostgreSQL runs in Docker.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=

# Database URLs
# For Dockerized local Postgres:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/alphabiohack?schema=public
# DIRECT_URL=postgresql://postgres:postgres@db:5432/alphabiohack?schema=public
#
# For Supabase Postgres:
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
DATABASE_URL=
DIRECT_URL=

# Resend API Key
# Required in production when EMAIL_PROVIDER=resend.
RESEND_API_KEY=

# Email transport
# Production can omit these and default to Resend.
# Local Docker injects EMAIL_PROVIDER=smtp, SMTP_HOST=mailpit, SMTP_PORT=1025.
# For local host-run app (`npm run dev`) with Mailpit in Docker, uncomment:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# BOOKING_FROM_EMAIL="AlphaBioHack <noreply@local.alphabiohack>"
# BOOKING_REPLY_TO=dev@local.alphabiohack
# BOOKING_EMAIL_BCC=

EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=


# Optional: address geocoding for locations
# If set, the app can try to derive coordinates and timezone from the full office address.
GOOGLE_MAPS_API_KEY=

# Optional: choose which company/tenant powers the public site.
# `DEFAULT_COMPANY_SLUG` is useful for server-side routes.
# `NEXT_PUBLIC_DEFAULT_COMPANY_SLUG` is useful for public client-side flows.
DEFAULT_COMPANY_SLUG=
NEXT_PUBLIC_DEFAULT_COMPANY_SLUG=

# Local auth cookie signing secret
# Required whenever Supabase auth is disabled.
LOCAL_AUTH_SECRET=


# Public booking therapist config
# This must be the Prisma users.id value for the therapist shown on public booking pages.
NEXT_PUBLIC_DEFAULT_THERAPIST_ID=
