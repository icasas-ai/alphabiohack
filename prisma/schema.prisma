generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  supabaseId            String     @unique
  managedByTherapistId  String?
  firstname             String
  lastname              String
  avatar                String?    @db.Text
  telefono              String?
  informacionPublica    String?
  especialidad          String?
  summary               String?    @db.Text
  passwordHash          String?
  mustChangePassword    Boolean    @default(false)
  facebook              String?
  instagram             String?
  linkedin              String?
  twitter               String?
  tiktok                String?
  youtube               String?
  website               String?
  role                  UserRole[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  patientBookings       Booking[]  @relation("PatientBookings")
  therapistBookings     Booking[]  @relation("TherapistBookings")
  managedByTherapist    User?      @relation("TherapistPersonnel", fields: [managedByTherapistId], references: [id], onDelete: SetNull)
  managedPersonnel      User[]     @relation("TherapistPersonnel")
  publicCompanies       Company[]  @relation("CompanyPublicTherapist")
  companyMemberships    CompanyMembership[]
  availabilityPeriods   AvailabilityPeriod[]
  availabilityDays      AvailabilityDay[]
  availabilityExcludedDates AvailabilityExcludedDate[]

  @@index([managedByTherapistId])
  @@map("users")
}

model Company {
  id                   String              @id @default(cuid())
  name                 String
  slug                 String              @unique
  logo                 String?             @db.Text
  publicEmail          String?
  publicPhone          String?
  publicDescription    String?             @db.Text
  publicSummary        String?             @db.Text
  publicSpecialty      String?
  defaultTimezone      String              @default("America/Los_Angeles")
  publicTherapistId    String?
  weekdaysHours        String?             @default("9:00 AM - 6:00 PM")
  saturdayHours        String?             @default("9:00 AM - 2:00 PM")
  sundayHours          String?             @default("Closed")
  facebook             String?
  instagram            String?
  linkedin             String?
  twitter              String?
  tiktok               String?
  youtube              String?
  website              String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  publicTherapist      User?               @relation("CompanyPublicTherapist", fields: [publicTherapistId], references: [id], onDelete: SetNull)
  memberships          CompanyMembership[]
  locations            Location[]
  specialties          Specialty[]
  services             Service[]
  bookings             Booking[]
  availabilityPeriods  AvailabilityPeriod[]
  availabilityDays     AvailabilityDay[]
  availabilityExcludedDates AvailabilityExcludedDate[]

  @@map("companies")
}

model CompanyMembership {
  id         String                @id @default(cuid())
  companyId  String
  userId     String
  role       CompanyMembershipRole
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  company    Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId, role])
  @@index([userId, role])
  @@map("company_memberships")
}

model Location {
  id            String          @id @default(cuid())
  companyId      String
  address       String
  logo          String?
  title         String
  description   String?
  lat           Float?
  lon           Float?
  timezone      String          @default("America/Los_Angeles")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  businessHours BusinessHours[]
  overrides     DateOverride[]
  availabilityPeriods AvailabilityPeriod[]
  availabilityDays    AvailabilityDay[]
  availabilityExcludedDates AvailabilityExcludedDate[]

  @@index([companyId, createdAt])
  @@map("locations")
}

model AvailabilityPeriod {
  id         String            @id @default(cuid())
  companyId   String
  therapistId String
  locationId String
  title      String?
  notes      String?
  startDate  DateTime          @db.Date
  endDate    DateTime          @db.Date
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  therapist  User              @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  location   Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  days       AvailabilityDay[]
  excludedDates AvailabilityExcludedDate[]

  @@index([companyId, therapistId, locationId, startDate, endDate])
  @@map("availability_periods")
}

model AvailabilityDay {
  id                     String                  @id @default(cuid())
  availabilityPeriodId   String
  companyId              String
  therapistId            String
  locationId             String
  date                   DateTime                @db.Date
  isAvailable            Boolean                 @default(true)
  sessionDurationMinutes Int                     @default(60)
  notes                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period                 AvailabilityPeriod      @relation(fields: [availabilityPeriodId], references: [id], onDelete: Cascade)
  therapist              User                    @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  location               Location                @relation(fields: [locationId], references: [id], onDelete: Cascade)
  timeRanges             AvailabilityTimeRange[]

  @@unique([therapistId, locationId, date])
  @@index([companyId, date])
  @@index([locationId, date])
  @@index([therapistId, date])
  @@map("availability_days")
}

model AvailabilityExcludedDate {
  id                     String                        @id @default(cuid())
  availabilityPeriodId   String
  companyId              String
  therapistId            String
  locationId             String
  date                   DateTime                      @db.Date
  sessionDurationMinutes Int                           @default(60)
  notes                  String?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  company                Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period                 AvailabilityPeriod            @relation(fields: [availabilityPeriodId], references: [id], onDelete: Cascade)
  therapist              User                          @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  location               Location                      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  timeRanges             AvailabilityExcludedTimeRange[]

  @@unique([availabilityPeriodId, date])
  @@index([companyId, date])
  @@index([locationId, date])
  @@index([therapistId, date])
  @@map("availability_excluded_dates")
}

model AvailabilityExcludedTimeRange {
  id                         String                   @id @default(cuid())
  availabilityExcludedDateId String
  startTime                  String
  endTime                    String
  isActive                   Boolean                  @default(true)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  availabilityExcludedDate   AvailabilityExcludedDate @relation(fields: [availabilityExcludedDateId], references: [id], onDelete: Cascade)

  @@unique([availabilityExcludedDateId, startTime, endTime])
  @@map("availability_excluded_time_ranges")
}

model AvailabilityTimeRange {
  id                String          @id @default(cuid())
  availabilityDayId String
  startTime         String
  endTime           String
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  availabilityDay   AvailabilityDay @relation(fields: [availabilityDayId], references: [id], onDelete: Cascade)

  @@unique([availabilityDayId, startTime, endTime])
  @@map("availability_time_ranges")
}

model BusinessHours {
  id         String     @id @default(cuid())
  dayOfWeek  DaysOfWeek
  locationId String
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  timeSlots  TimeSlot[]

  @@unique([locationId, dayOfWeek])
  @@map("business_hours")
}

model TimeSlot {
  id              String        @id @default(cuid())
  startTime       String
  endTime         String
  isActive        Boolean       @default(true)
  businessHoursId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  businessHours   BusinessHours @relation(fields: [businessHoursId], references: [id], onDelete: Cascade)

  @@unique([businessHoursId, startTime, endTime])
  @@map("time_slots")
}

model DateOverride {
  id         String             @id @default(cuid())
  locationId String
  startDate  DateTime
  endDate    DateTime
  isClosed   Boolean            @default(true)
  reason     String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  location   Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  timeSlots  OverrideTimeSlot[]

  @@index([locationId, startDate, endDate])
  @@map("date_overrides")
}

model OverrideTimeSlot {
  id             String       @id @default(cuid())
  startTime      String
  endTime        String
  isActive       Boolean      @default(true)
  dateOverrideId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  dateOverride   DateOverride @relation(fields: [dateOverrideId], references: [id], onDelete: Cascade)

  @@unique([dateOverrideId, startTime, endTime])
  @@map("override_time_slots")
}

model Specialty {
  id          String    @id @default(cuid())
  companyId    String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  services    Service[]

  @@index([companyId, name])
  @@map("specialties")
}

model Service {
  id          String    @id @default(cuid())
  companyId    String
  description String
  cost        Float
  duration    Int
  specialtyId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("services")
}

model Booking {
  id              String        @id @default(cuid())
  companyId        String
  bookingType     BookingType
  locationId      String
  specialtyId     String?
  serviceId       String?
  bookedDurationMinutes Int?
  firstname       String
  lastname        String
  phone           String
  email           String
  givenConsent    Boolean       @default(false)
  therapistId     String?
  patientId       String?
  bookingNotes    String?
  bookingSchedule DateTime
  status          BookingStatus @default(Pending)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location        Location      @relation(fields: [locationId], references: [id])
  patient         User?         @relation("PatientBookings", fields: [patientId], references: [id])
  service         Service?      @relation(fields: [serviceId], references: [id])
  specialty       Specialty?    @relation(fields: [specialtyId], references: [id])
  therapist       User?         @relation("TherapistBookings", fields: [therapistId], references: [id])

  @@index([companyId, bookingSchedule])
  @@index([therapistId, bookingSchedule])
  @@index([patientId, bookingSchedule])
  @@index([status, bookingSchedule])
  @@map("bookings")
}

enum BookingType {
  DirectVisit
  VideoCall
  PhoneCall
  HomeVisit
}

enum DaysOfWeek {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

enum UserRole {
  Therapist
  Admin
  FrontDesk
  Patient
}

enum CompanyMembershipRole {
  Owner
  Therapist
  FrontDesk
  Patient
}

enum BookingStatus {
  Pending
  Confirmed
  InProgress
  Completed
  Cancelled
  NoShow
}
