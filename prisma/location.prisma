model Location {
  id                        String                   @id @default(cuid())
  companyId                 String
  address                   String
  logo                      String?
  title                     String
  description               String?
  lat                       Float?
  lon                       Float?
  timezone                  String                   @default("America/Los_Angeles")
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  company                   Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bookings                  Booking[]
  businessHours             BusinessHours[]
  overrides                 DateOverride[]
  availabilityPeriods       AvailabilityPeriod[]
  availabilityDays          AvailabilityDay[]
  availabilityExcludedDates AvailabilityExcludedDate[]

  @@index([companyId, createdAt])
  @@map("locations")
}

model BusinessHours {
  id         String     @id @default(cuid())
  dayOfWeek  DaysOfWeek
  locationId String
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  timeSlots  TimeSlot[]

  @@unique([locationId, dayOfWeek])
  @@map("business_hours")
}

model TimeSlot {
  id              String        @id @default(cuid())
  startTime       String
  endTime         String
  isActive        Boolean       @default(true)
  businessHoursId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  businessHours   BusinessHours @relation(fields: [businessHoursId], references: [id], onDelete: Cascade)

  @@unique([businessHoursId, startTime, endTime])
  @@map("time_slots")
}

model DateOverride {
  id         String             @id @default(cuid())
  locationId String
  startDate  DateTime
  endDate    DateTime
  isClosed   Boolean            @default(true)
  reason     String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  location   Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  timeSlots  OverrideTimeSlot[]

  @@index([locationId, startDate, endDate])
  @@map("date_overrides")
}

model OverrideTimeSlot {
  id             String       @id @default(cuid())
  startTime      String
  endTime        String
  isActive       Boolean      @default(true)
  dateOverrideId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  dateOverride   DateOverride @relation(fields: [dateOverrideId], references: [id], onDelete: Cascade)

  @@unique([dateOverrideId, startTime, endTime])
  @@map("override_time_slots")
}
