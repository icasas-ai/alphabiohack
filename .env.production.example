# Site URL
# Use your canonical production URL here.
SITE_URL=https://your-site.netlify.app
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# Supabase Auth / Storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your-supabase-anon-key
# Required for personnel invite/reset flows when Supabase auth is enabled.
SUPABASE_SERVICE_ROLE_KEY=

# Database connection (required)
# Runtime should usually use Supabase session-pooler host/port.
DB_USER=postgres
DB_PASS=
DB_HOST=
DB_PORT=6543
DB_NAME=postgres
# Optional query params appended to the connection string, e.g.:
# DB_QUERY=pgbouncer=true&sslmode=require
DB_QUERY=pgbouncer=true&sslmode=require

# Legacy compatibility fallback (not recommended):
# DATABASE_URL=

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
BOOKING_FROM_EMAIL="AlphaBioHack <noreply@example.com>"
BOOKING_REPLY_TO=support@example.com
BOOKING_EMAIL_BCC=

# Public company selection
DEFAULT_COMPANY_SLUG=default-company
NEXT_PUBLIC_DEFAULT_COMPANY_SLUG=default-company

# Optional location geocoding
GOOGLE_MAPS_API_KEY=

# Optional client-side calendar organizer email
NEXT_PUBLIC_BOOKING_FROM_EMAIL=noreply@example.com

# Production bootstrap seed
# Run `npm run db:seed:prod` once after migrations.
BOOTSTRAP_COMPANY_SLUG=default-company
BOOTSTRAP_COMPANY_NAME=AlphaBioHack Practice
BOOTSTRAP_COMPANY_TIMEZONE=America/Los_Angeles
BOOTSTRAP_PUBLIC_EMAIL=therapist@example.com
BOOTSTRAP_PUBLIC_PHONE=+15551234567
BOOTSTRAP_PUBLIC_DESCRIPTION=Therapist-led practice profile used for the public website.
BOOTSTRAP_PUBLIC_SUMMARY=Book appointments, review availability, and stay connected with your care team.
BOOTSTRAP_PUBLIC_SPECIALTY=Therapist Services
BOOTSTRAP_OWNER_EMAIL=owner@example.com

# Optional:
# If the owner has not yet created a Prisma user row, set the Supabase auth user id
# so the production seed can create the Prisma-side user record.
BOOTSTRAP_OWNER_SUPABASE_ID=
BOOTSTRAP_OWNER_FIRSTNAME=Practice
BOOTSTRAP_OWNER_LASTNAME=Owner
BOOTSTRAP_OWNER_AVATAR=
