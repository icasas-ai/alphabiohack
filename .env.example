# Supabase Storage (optional)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=

# Database connection (required)
# Prisma runtime/CLI compose the DB URL internally from these values.
DB_USER=
DB_PASS=
DB_HOST=
DB_PORT=5432
DB_NAME=
# Optional query params appended to the connection string, e.g.:
# DB_QUERY=pgbouncer=true&sslmode=require&uselibpqcompat=true
DB_QUERY=

# Legacy compatibility fallback (not recommended):
# DATABASE_URL=

# Resend API Key
# Required in production when EMAIL_PROVIDER=resend.
RESEND_API_KEY=

# Email transport
# Production can omit these and default to Resend.
# Local Docker injects EMAIL_PROVIDER=smtp, SMTP_HOST=mailpit, SMTP_PORT=1025.
# For local host-run app (`npm run dev`) with Mailpit in Docker, uncomment:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# BOOKING_FROM_EMAIL="CompanyName <noreply@local.myalphapulse>"
# BOOKING_REPLY_TO=dev@local.myalphapulse
# BOOKING_EMAIL_BCC=

EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=


# Required: choose which company powers the public site for this deployment.
DEFAULT_COMPANY_SLUG=

# App auth cookie signing secret
# Required in every environment because auth is app-managed.
APP_AUTH_SECRET=
